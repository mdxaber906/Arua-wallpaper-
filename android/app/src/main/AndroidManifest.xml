<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.aurawallpapers.app">

    <application
        android:label="Aura Wallpapers"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round">

        <!-- ✅ IMPORTANT: Flutter V2 Embedding -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">

            <!-- Flutter launch theme -->
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ✅ VIDEO LIVE WALLPAPER -->
        <service
            android:name=".service.VideoLiveWallpaperService"
            android:label="Aura Video Wallpaper"
            android:permission="android.permission.BIND_WALLPAPER"
            android:exported="false">

            <intent-filter>
                <action android:name="android.service.wallpaper.WallpaperService" />
            </intent-filter>

            <meta-data
                android:name="android.service.wallpaper"
                android:resource="@xml/video_wallpaper" />
        </service>

        <!-- ✅ PARALLAX LIVE WALLPAPER -->
        <service
            android:name=".service.ParallaxLiveWallpaperService"
            android:label="Aura Motion Wallpaper"
            android:permission="android.permission.BIND_WALLPAPER"
            android:exported="false">

            <intent-filter>
                <action android:name="android.service.wallpaper.WallpaperService" />
            </intent-filter>

            <meta-data
                android:name="android.service.wallpaper"
                android:resource="@xml/parallax_wallpaper" />
        </service>

    </application>
</manifest>
